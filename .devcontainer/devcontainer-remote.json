{
  "build": {
    "context": ".",
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/nix:1": {
      "multiUser": false
    }
  },
  "containerEnv": {
    "CHEZMOI_SOURCE_DIR": "/home/vscode/.local/share/chezmoi",
    "DISPLAY": ":100",
    "GITHUB_TOKEN": "${localEnv:GITHUB_PAT_PUBLIC_REPO}",
    "AQUA_GITHUB_TOKEN": "${localEnv:GITHUB_PAT_PUBLIC_REPO}",
    "GIT_COMMITTER_EMAIL": "${localEnv:GIT_COMMITTER_EMAIL}",
    "GIT_COMMITTER_NAME": "${localEnv:GIT_COMMITTER_NAME}",
    "GIT_AUTHOR_NAME": "${localEnv:GIT_AUTHOR_NAME}",
    "GIT_AUTHOR_EMAIL": "${localEnv:GIT_AUTHOR_EMAIL}",
    "GOOGLE_API_KEY": "${localEnv:GOOGLE_API_KEY}",
    "GEMINI_API_KEY": "${localEnv:GOOGLE_API_KEY}"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/vscode/.local/share/chezmoi,type=bind",
  "workspaceFolder": "/home/vscode/.local/share/chezmoi",
  "mounts": [
    // Persistent caches. A *named* volume (source=<name>,type=volume) is a
    // Docker object with its own lifecycle: containers only attach to it, so
    // `--recreate` and the weekly cleanup leave it intact (`docker volume
    // prune` only removes *anonymous* volumes). On first mount over a
    // non-empty image path (/nix), Docker seeds the empty volume from the
    // image; afterwards the volume always wins over image content. To re-seed
    // after a nix feature upgrade: `docker volume rm devpod-nix`.
    "source=devpod-nix,target=/nix,type=volume",
    "source=devpod-mise,target=/home/vscode/.local/share/mise,type=volume",
    "source=devpod-cache,target=/home/vscode/.cache,type=volume",
    "source=${localEnv:HOME}/.ssh/git-signing.pub,target=/mnt/host/git-signing.pub,type=bind,readonly",
    "source=${localEnv:HOME}/.local/share/opencode,target=/home/vscode/.local/share/opencode,type=bind"
  ],
  "runArgs": [
    "--net=host"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "saoudrizwan.claude-dev",
        "esbenp.prettier-vscode",
        "astro-build.astro-vscode"
      ]
    },
    "settings": {
      "editor.defaultFormatter": "esbenp.prettier-vscode",
      "editor.formatOnSave": true,
      "prettier.semi": false,
      "[astro]": {
        "editor.defaultFormatter": "astro-build.astro-vscode"
      },
      "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      },
      "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  },
  // First line of defense only — Dockerfile seeds ownership, `setup` self-heals.
  "onCreateCommand": "sudo chown vscode:vscode /home/vscode/.cache /home/vscode/.local /home/vscode/.local/share/mise || true",
  "updateContentCommand": "sudo apt-get update && sudo DEBIAN_FRONTEND=noninteractive apt-get install -y wget gnupg2 && wget -qO - https://xpra.org/gpg.asc | sudo gpg --dearmor -o /usr/share/keyrings/xpra.gpg && . /etc/os-release && echo \"deb [arch=amd64 signed-by=/usr/share/keyrings/xpra.gpg] https://xpra.org/ $VERSION_CODENAME main\" | sudo tee /etc/apt/sources.list.d/xpra.list && sudo apt-get update && sudo DEBIAN_FRONTEND=noninteractive apt-get install -y xpra xvfb",
  "postCreateCommand": ".devcontainer/scripts/setup && bash /home/vscode/.local/share/chezmoi/setup",
  "postStartCommand": "mkdir -p /tmp/xpra-runtime && env XDG_RUNTIME_DIR=/tmp/xpra-runtime xpra start :100 --bind-tcp=0.0.0.0:10000 --daemon=yes --mdns=no --auth=none"
}
