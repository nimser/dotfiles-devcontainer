#!/usr/bin/bash
{{- if and (eq .chezmoi.hostname "tpad") (not (stat "/.dockerenv")) }}
# cpu-watchdog.service hash: {{ include "private_dot_config/systemd/user/cpu-watchdog.service" | sha256sum }}
# docker-cleanup.timer hash: {{ include "private_dot_config/systemd/user/docker-cleanup.timer" | sha256sum }}
# docker-cleanup.service hash: {{ include "private_dot_config/systemd/user/docker-cleanup.service" | sha256sum }}
# zettelkasten-inotify.service hash: {{ include "private_dot_config/systemd/user/encrypted_zettelkasten-inotify.service.age" | sha256sum }}
# rclone-backup.timer hash: {{ include "private_dot_config/systemd/user/rclone-backup.timer" | sha256sum }}
# rclone-backup.service hash: {{ include "private_dot_config/systemd/user/encrypted_rclone-backup.service.age" | sha256sum }}
# age-plugin-tpm-bridge-identity.service hash: {{ include "private_dot_config/systemd/user/age-plugin-tpm-bridge-identity.service" | sha256sum }}
# age-plugin-tpm-bridge-recipient.service hash: {{ include "private_dot_config/systemd/user/age-plugin-tpm-bridge-recipient.service" | sha256sum }}
# age-plugin-yubikey-bridge-identity.service hash: {{ include "private_dot_config/systemd/user/age-plugin-yubikey-bridge-identity.service" | sha256sum }}
# age-plugin-yubikey-bridge-recipient.service hash: {{ include "private_dot_config/systemd/user/age-plugin-yubikey-bridge-recipient.service" | sha256sum }}
# claude-swap.service hash: {{ include "private_dot_config/systemd/user/claude-swap.service" | sha256sum }}
# claude-swap.timer hash: {{ include "private_dot_config/systemd/user/claude-swap.timer" | sha256sum }}
# chezmoi-refresh-externals.service hash: {{ include "private_dot_config/systemd/user/chezmoi-refresh-externals.service" | sha256sum }}
# chezmoi-refresh-externals.timer hash: {{ include "private_dot_config/systemd/user/chezmoi-refresh-externals.timer" | sha256sum }}
# devpod-mise-warm.service hash: {{ include "private_dot_config/systemd/user/devpod-mise-warm.service" | sha256sum }}
# devpod-mise-warm.timer hash: {{ include "private_dot_config/systemd/user/devpod-mise-warm.timer" | sha256sum }}
# devpod-mise-warm script hash: {{ include "private_dot_local/bin/executable_devpod-mise-warm" | sha256sum }}
# Dockerfile.mise-warm hash: {{ include ".devcontainer/Dockerfile.mise-warm" | sha256sum }}

set -euo pipefail

systemctl --user daemon-reload

# Enable the units so they start on boot
systemctl --user enable cpu-watchdog.service
systemctl --user enable docker-cleanup.timer
systemctl --user enable zettelkasten-inotify.service
systemctl --user enable rclone-backup.timer
systemctl --user enable age-plugin-tpm-bridge-identity.service
systemctl --user enable age-plugin-tpm-bridge-recipient.service
systemctl --user enable age-plugin-yubikey-bridge-identity.service
systemctl --user enable age-plugin-yubikey-bridge-recipient.service
systemctl --user enable claude-swap.timer
systemctl --user enable chezmoi-refresh-externals.timer
systemctl --user enable devpod-mise-warm.timer

# Restart them to pick up any changes (and start them if they weren't running)
systemctl --user restart cpu-watchdog.service
systemctl --user restart docker-cleanup.timer
systemctl --user restart zettelkasten-inotify.service
systemctl --user restart rclone-backup.timer
systemctl --user restart age-plugin-tpm-bridge-identity.service
systemctl --user restart age-plugin-tpm-bridge-recipient.service
systemctl --user restart age-plugin-yubikey-bridge-identity.service
systemctl --user restart age-plugin-yubikey-bridge-recipient.service
systemctl --user restart claude-swap.timer
systemctl --user restart chezmoi-refresh-externals.timer
systemctl --user restart devpod-mise-warm.timer
{{- end }}
