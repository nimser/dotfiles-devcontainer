#!/usr/bin/bash
# packages hash: {{ include "private_dot_config/mise/config.toml.tmpl" | sha256sum }}

set -euo pipefail

mise_cmd=$(which mise)
if command -v $mise_cmd >/dev/null; then
  $mise_cmd trust
  # mise hides progress when output is piped (as chezmoi does); a cold
  # version cache means ~30-60s of silent GitHub API resolution for all
  # the `latest` tools. Print something so it doesn't look hung.
  echo ">> mise install: resolving latest versions (can take ~1min)..."
  $mise_cmd install
fi
if command -v tldr >/dev/null; then
  tldr --update
fi
if command -v bat >/dev/null; then
  # needed to load the custom colorscheme
  bat cache --build
fi
