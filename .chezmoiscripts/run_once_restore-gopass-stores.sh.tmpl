{{- if (and (eq .chezmoi.hostname "tpad") (not (stat "/.dockerenv"))) -}}
{{ include "private_dot_local/bin/executable_rclone-restore" -}}
{{- else -}}
#!/usr/bin/env bash
set -euo pipefail

STORES_DIR="$HOME/.local/share/gopass/stores"

# Set up git-signing.pub and gopass-depoly-key symlinks (chezmoi already created ~/.ssh with correct perms)
if [ -f /mnt/host/git-signing.pub ]; then
    mkdir -p ~/.ssh
    chmod 700 ~/.ssh
    ln -sf /mnt/host/git-signing.pub ~/.ssh/git-signing.pub
    cp /mnt/host/gopass-deploy-key ~/.ssh/gopass-deploy-key
    chmod 600 ~/.ssh/gopass-deploy-key
fi

# Restore bg store from GitLab
if [ ! -d "$STORES_DIR/bg/.git" ]; then
    TMP_SSH_DIR=$(mktemp -d)
    GIT_SSH_COMMAND="ssh -i ~/.ssh/gopass-deploy-key -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new -o BatchMode=yes -o ConnectTimeout=5 -o UserKnownHostsFile=$TMP_SSH_DIR/known_hosts" git clone git@gitlab.com:nimser/coffre-fort-bg.git "$STORES_DIR/bg"
fi

# Persist deploy-key transport for all subsequent git ops in the bg store
# (gopass sync / cli.autopush from agent or CLI), bypassing the SSH agent
# and thus any YubiKey touch prompt. IdentitiesOnly=yes prevents agent keys
# from being offered; commit signing still uses the agent as usual.
if [ -d "$STORES_DIR/bg/.git" ]; then
    git -C "$STORES_DIR/bg" config core.sshCommand \
        'ssh -i ~/.ssh/gopass-deploy-key -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new -o BatchMode=yes -o ConnectTimeout=5'
fi
{{- end }}
