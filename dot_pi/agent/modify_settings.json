#!/usr/bin/env python3
# chezmoi modify_ script: merges managed keys into pi's settings.json,
# leaving all other keys (e.g. lastChangelogVersion) untouched.
import json, sys

current = json.load(sys.stdin) if sys.stdin.readable() else {}

managed = {
    "defaultProvider": "anthropic",
    "defaultModel": "claude-sonnet-4-6",
    "packages": [
        "../../.local/share/mise/installs/npm-gotgenes-pi-anthropic-auth/latest/lib/node_modules/@gotgenes/pi-anthropic-auth"
    ],
    "warnings": {
        "anthropicExtraUsage": False
    },
    # Model list shown by default (Ctrl+P cycling / /model picker).
    #
    # Why anthropic models are listed explicitly instead of "anthropic/*":
    # pi's glob matcher tests both `provider/id` AND the bare `id`. OpenRouter
    # anthropic models have bare ids like "anthropic/claude-opus-4.8", so the
    # glob "anthropic/*" also pulls in every OpenRouter anthropic model.
    # Worse, "anthropic/claude-fable-5" is identical as an Anthropic-provider
    # fullId and an OpenRouter bare id, so no glob can separate them. Exact
    # `anthropic/<id>` references use canonical provider/id matching and stay
    # scoped to the Anthropic subscription. Re-run `pi --list-models` after
    # upgrading pi and append any new Anthropic-provider models here.
    "enabledModels": [
        "opencode-go/*",
        # Anthropic subscription (all models, exact refs to avoid OpenRouter bleed)
        "anthropic/claude-3-5-haiku-20241022",
        "anthropic/claude-3-5-haiku-latest",
        "anthropic/claude-3-5-sonnet-20240620",
        "anthropic/claude-3-5-sonnet-20241022",
        "anthropic/claude-3-7-sonnet-20250219",
        "anthropic/claude-3-haiku-20240307",
        "anthropic/claude-3-opus-20240229",
        "anthropic/claude-3-sonnet-20240229",
        "anthropic/claude-fable-5",
        "anthropic/claude-haiku-4-5",
        "anthropic/claude-haiku-4-5-20251001",
        "anthropic/claude-opus-4-0",
        "anthropic/claude-opus-4-1",
        "anthropic/claude-opus-4-1-20250805",
        "anthropic/claude-opus-4-20250514",
        "anthropic/claude-opus-4-5",
        "anthropic/claude-opus-4-5-20251101",
        "anthropic/claude-opus-4-6",
        "anthropic/claude-opus-4-7",
        "anthropic/claude-opus-4-8",
        "anthropic/claude-sonnet-4-0",
        "anthropic/claude-sonnet-4-20250514",
        "anthropic/claude-sonnet-4-5",
        "anthropic/claude-sonnet-4-5-20250929",
        "anthropic/claude-sonnet-4-6",
        # OpenRouter (only these three)
        "openrouter/anthropic/claude-opus-4.8",
        "openrouter/z-ai/glm-5.2",
        "openrouter/openai/gpt-5.5"
    ],
}

current.update(managed)
print(json.dumps(current, indent=2))
