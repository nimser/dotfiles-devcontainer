# vim: set filetype=toml:
[tools]
# base, EVERYWHERE
chezmoi = "latest"
neovim = "latest"
delta = "latest"
lazygit = "latest"
bat = "latest"
"github:bartei/git-agecrypt" = "latest"
"aqua:tealdeer-rs/tealdeer" = "1.8.1"
"aqua:sharkdp/fd" = "latest"
"github:BurntSushi/ripgrep" = "latest"
"aqua:cli/cli" = "latest" #github-cli
"gitlab:gitlab-org/cli" = "latest" #gitlab-cli
"aqua:tree-sitter/tree-sitter" = "latest"
"github:fish-shell/fish-shell" = "latest"
"aqua:dprint/dprint" = "latest"
"aqua:mvdan/sh" = "latest" # shfmt
"github:pkgxdev/pkgx" = "latest"
"github:pkgxdev/pkgm" = "latest"
direnv = "latest"
node = "latest"
uv = "latest"
viteplus = "latest"
"github:sst/opencode" = "latest"
# github backend, not the aqua default: aqua-registry lags upstream releases for
# pi (stale/missing checksums right after a release), which broke `mise upgrade`
# more than once. github: installs straight from the GH release + verifies
# artifact attestation/SLSA provenance, so `latest` is safe to track again.
"github:earendil-works/pi" = "latest"
claude = "latest"
"npm:pi-claude-auth" = "latest"
fzf = "latest"
age = "latest"
gopass = "1.17.0-rc.2"
sops = "latest"
#gcloud = "latest"
yq = "latest"
jq = "1.8.1"
"aqua:nushell/nushell" = "latest"
{{- if (and (eq .chezmoi.hostname "tpad") (not (stat "/.dockerenv")))}} 
# only for tpad itself, excluding containers running on it
"github:yt-dlp/yt-dlp" = "latest"
"pipx:realiti4/claude-swap" = "latest"
"github:olastor/age-plugin-fido2-hmac" = "latest"
"github:Foxboron/age-plugin-tpm" = "latest"
"github:str4d/age-plugin-yubikey" = "0.5.0"
"github:cjpais/Handy" = { version = "latest", matching = "AppImage" }
{{- end }}
{{- if (eq (env "DEVPOD_WORKSPACE_ID") "homelab")}}
# only for the homelab devpod
kubectl = "latest"
kubectx = "latest"
kubens = "latest"
helm = "latest"
"aqua:k9s" = "latest"
"aqua:fluxcd/flux2" = "latest"
"aqua:siderolabs/talos" = "latest" # talosctl
{{- end}}
[settings]
idiomatic_version_file_enable_tools = ["node"]
minimum_release_age = "1h" # don't install something younger that this age
use_versions_host = false # disable using `mise-versions` (https://mise-versions.jdx.dev/) use github api directly instead
fetch_remote_versions_cache = "1h" # default
cache_prune_age = "7d" # default is 30d too long
